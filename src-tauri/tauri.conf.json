{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DizzyPlay",
  "version": "../package.json",
  "identifier": "com.liaronce.dizzyplay",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DizzyPlay",
        "width": 1200,
        "height": 800,
        "decorations": false,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/64x64.png",
      "iconAsTemplate": true,
      "tooltip": "DizzyPlay"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "copyright": "",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  }
}